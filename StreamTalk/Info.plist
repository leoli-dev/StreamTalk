<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleName</key>
    <string>StreamTalk</string>
    <key>CFBundleDisplayName</key>
    <string>StreamTalk</string>
    <key>CFBundleIdentifier</key>
    <string>com.leo.streamtalk</string>
    <key>CFBundleExecutable</key>
    <string>StreamTalk</string>
    <key>CFBundleIconFile</key>
    <string>AppIcon</string>
    <key>CFBundleIconName</key>
    <string>AppIcon</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>LSMinimumSystemVersion</key>
    <string>14.0</string>
    <!-- TCC permission prompts require these strings. -->
    <key>NSMicrophoneUsageDescription</key>
    <string>StreamTalk 需要麦克风来听你说话。</string>
    <key>NSSpeechRecognitionUsageDescription</key>
    <string>StreamTalk 需要语音识别把你的话转成文字。</string>
    <!-- Needed so the app (and its TTS-proxy child) can reach the LAN
         CosyVoice server (e.g. pc-lan.home / 10.44.44.x). -->
    <key>NSLocalNetworkUsageDescription</key>
    <string>StreamTalk 需要访问内网来连接你内网 PC 上的 TTS 服务器。</string>
    <!-- The TTS server is plain HTTP on the LAN (http://pc-lan.home:5055).
         macOS ATS blocks non-HTTPS to non-loopback hosts by default. -->
    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSAllowsArbitraryLoads</key>
        <true/>
    </dict>
</dict>
</plist>
