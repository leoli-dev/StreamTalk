# StreamTalk config — copy this to ~/.config/streamtalk/.env
# (or point $STREAMTALK_ENV at a file). These are read on first run to seed
# defaults; you can also just enter everything in the app's Settings instead.
# This file (.env) is gitignored — never commit real keys.

# Local OpenAI-compatible LLM (e.g. an MLX server). Leave key blank if none.
STREAMTALK_LOCAL_KEY=your-local-llm-key
STREAMTALK_LLM_BASE=http://127.0.0.1:8000/v1
STREAMTALK_LLM_MODEL=your-model-id

# CosyVoice TTS FastAPI base URL (the prerequisite TTS service — see README).
STREAMTALK_TTS_SERVER=http://your-tts-host:5055
